# Copy to .env.local (local) or set in Render/Railway dashboard (staging/production).
# Never commit real secrets.

# =============================================================================
# OBLIGATORIAS EN PRODUCCIÓN
# =============================================================================

NODE_ENV=production

# staging | production — en Render staging usar APP_ENV=staging (permite DEMO_MODE)
# APP_ENV=production

# PostgreSQL — Supabase pooler (app runtime, puerto 6543)
# postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Auth — mínimo 32 caracteres aleatorios en producción
JWT_SECRET=change-me-min-32-chars-random-string-here

# Cron — obligatorio en producción (GET /api/cron/notifications?secret=...)
CRON_SECRET=change-me-cron-secret-min-16-chars

# Superadmin SaaS — no se expone en getAppConfig
SUPERADMIN_USERNAME=change-me-superadmin
SUPERADMIN_PASSWORD=change-me-strong-superadmin-password

# URLs públicas (HTTPS en producción) — mismo dominio en monolito Render
FRONTEND_URL=https://app.example.com
VITE_APP_URL=https://app.example.com

# Puerto — Render/Railway lo inyectan automáticamente
PORT=3000

# =============================================================================
# RECOMENDADAS
# =============================================================================

# Sesión JWT/cookie (default 7 días en shared/const.ts)
# SESSION_MAX_AGE_DAYS=7

# Cron interno (setInterval). En producción usar false + cron HTTP externo
CRON_INTERNAL=false

# Push notifications (opcional)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@timeclock.app

# Google Maps en cliente (opcional)
# VITE_GOOGLE_MAPS_API_KEY=

# WhatsApp y precios de la landing: configurar en /superadmin → pestaña Web / Landing

# =============================================================================
# STRIPE — facturación automática (opcional; sin esto = planes manuales en superadmin)
# =============================================================================
# Dashboard: https://dashboard.stripe.com
# Webhook URL: https://TU-DOMINIO.com/api/stripe/webhook
# Eventos: checkout.session.completed, customer.subscription.updated,
#          customer.subscription.deleted, invoice.payment_failed

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
VITE_STRIPE_PUBLISHABLE_KEY=

# Logs: info | warn | error (futuro — documentado)
# LOG_LEVEL=info

# =============================================================================
# OPCIONALES
# =============================================================================

# Demo — permitido en local/staging. NO usar true en producción (preflight falla)
# DEMO_MODE=true

# Solo si frontend y API están en dominios distintos (no recomendado en v1)
# VITE_API_BASE_URL=

# Legacy OAuth/Manus/Forge (no requerido para SaaS self-service)
# VITE_APP_ID=timeclock-app
# OAUTH_SERVER_URL=
# OWNER_OPEN_ID=

# Supabase client-side (si aplica)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Migraciones — usar conexión DIRECTA (puerto 5432), no pooler:
# DATABASE_URL_DIRECT=postgresql://postgres:...@db.xxx.supabase.co:5432/postgres
